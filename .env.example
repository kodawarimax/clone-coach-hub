# AI Clone clients directory (where profile.json files live)
# Default: ~/Claude/Service/Clone/clients
CLONE_CLIENTS_DIR=/path/to/your/Clone/clients

# VPS hostname for SSH operations (restart, deploy, logs)
# Default: 72.61.119.101
CLONE_VPS_HOST=your.vps.host

# Clone server URL (for admin API proxy)
CLONE_SERVER_URL=https://your-clone-server.example.com

# Admin API key for clone creation and voice cloning
CLONE_ADMIN_API_KEY=your_admin_api_key_here

# App port (default: 3200)
PORT=3200
